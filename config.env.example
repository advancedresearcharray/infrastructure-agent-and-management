# Infrastructure Agent and Management
# Copy to /etc/default/ara-sys-agent and set your fleet endpoints.
# ARA_SYS_VMID=<your-proxmox-guest-id>
ARA_SYS_PORT=7860
ARA_SYS_OLLAMA_URL=http://127.0.0.1:11434
ARA_SYS_OLLAMA_MODEL=qwen2.5-coder:14b
ARA_SYS_DATA_DIR=/opt/ara-sys-agent/data
ARA_FLEET_CONFIG=/opt/ara-sys-agent/fleet.config.json
ARA_GUEST_MAP=/opt/ara-sys-agent/data/guest-map.json
# Array MCP gateway — full infra control plane
ARA_MCP_GATEWAY_URL=http://mcp-gateway.example:8090
ARA_SYS_MCP_AGENT_ID=node9-sre
ARA_AGENT_TOKEN_FILE=/opt/ara-sys-agent/secrets/array-agent-tokens.json
